# Required for data collection
ALCHEMY_SUI_RPC=https://sui-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
DATABASE_URL=postgresql://user:password@host:5432/navi_dashboard

# Optional: Cron authentication
CRON_SECRET=your-random-secret-here

# Optional: Upstash QStash (for scheduled crons on free tier)
QSTASH_TOKEN=your-qstash-token

# Optional: App URL (for QStash setup)
APP_URL=https://your-app.vercel.app
